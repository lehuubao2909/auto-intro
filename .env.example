# --- LLM provider -----------------------------------------------------------
# Which provider directs the storyboard + skims the repo. Default: gemini.
# AUTOINTRO_PROVIDER=gemini        # gemini | openai | anthropic

# Set the key for whichever provider you use (only the active one is required):
GEMINI_API_KEY=                    # https://aistudio.google.com/apikey  (also accepts GOOGLE_API_KEY)
# OPENAI_API_KEY=                  # https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=               # https://console.anthropic.com/settings/keys

# --- Optional model overrides (per-provider defaults shown) -------------------
# Director = storyboard synthesis (strongest) · Triage = cheap/fast repo skim.
#   gemini    -> gemini-3.5-flash      / gemini-3.1-flash-lite   (default)
#   openai    -> gpt-5.4               / gpt-5.4-mini
#   anthropic -> claude-opus-4-8       / claude-haiku-4-5
# AUTOINTRO_DIRECTOR_MODEL=
# AUTOINTRO_TRIAGE_MODEL=

# --- Optional video / server overrides ---------------------------------------
# AUTOINTRO_FPS=30
# AUTOINTRO_WIDTH=1920
# AUTOINTRO_HEIGHT=1080
# AUTOINTRO_PORT=0
